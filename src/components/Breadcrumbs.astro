---
import type { LanguageKey } from "@/config/languages";

import { t } from "../locales";

export interface BreadcrumbItem {
  label: string;
  url?: string; // undefined for current page
}

interface Props {
  items: BreadcrumbItem[];
  lang: LanguageKey;
}

export function generateBreadcrumbSchema(items: BreadcrumbItem[], baseUrl: string): object {
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.label,
      ...(item.url && { item: `${baseUrl}${item.url}` }),
    })),
  };
}

const { items, lang } = Astro.props;
---

<nav class="breadcrumbs" aria-label={t(lang, "breadcrumbs.ariaLabel")} data-pagefind-ignore>
  <ol class="breadcrumbs__list">
    {
      items.map((item, _index) => (
        <li class="breadcrumbs__item">
          {item.url ? (
            <a href={item.url} class="breadcrumbs__link">
              {item.label}
            </a>
          ) : (
            <span class="breadcrumbs__current" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
